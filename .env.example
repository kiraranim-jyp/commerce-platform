# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Prisma)
DATABASE_URL=
DIRECT_URL=

# OpenAI (선택, 유료 Provider)
OPENAI_API_KEY=

# Gemini (무료 1차 이미지 분류 Provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Naver Commerce
NAVER_LOGIN_ID=
NAVER_LOGIN_PASSWORD=

# Browser Agent
BROWSER_HEADLESS=true
BROWSER_STORAGE_DIR=storage/sessions

# Crawler
CRAWLER_MIN_IMAGE_WIDTH=200
CRAWLER_MIN_IMAGE_HEIGHT=200
CRAWLER_NAV_TIMEOUT_MS=30000

# Image Pipeline
IMAGE_STORAGE_ROOT=storage
IMAGE_LOGS_ROOT=logs
IMAGE_STANDARD_WIDTH=1500
IMAGE_STANDARD_HEIGHT=2000
IMAGE_STANDARD_BACKGROUND=white
IMAGE_STANDARD_JPEG_QUALITY=95
IMAGE_UPSCALE_THRESHOLD_WIDTH=1500
IMAGE_UPSCALE_THRESHOLD_HEIGHT=2000
IMAGE_REMOVE_BACKGROUND_FOR=PRODUCT
OPENAI_VISION_MODEL=gpt-4o-mini
MARKETPLACE=NAVER
