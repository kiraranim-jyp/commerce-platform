generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id        String   @id @default(cuid())
  sourceUrl String   @unique
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
